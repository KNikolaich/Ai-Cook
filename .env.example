# NEXT_PUBLIC_GEMINI_API_KEY: Required for Gemini AI API calls on the client side.
# AI Studio automatically injects this at runtime from user secrets.
NEXT_PUBLIC_GEMINI_API_KEY=""

# AI_MODEL: The model to use for analysis and chat.
AI_MODEL="gemini-2.5-flash"

# AI_TEMPERATURE: Controls randomness.
AI_TEMPERATURE=0.7

# NEXT_PUBLIC_APP_URL: The URL where this applet is hosted.
NEXT_PUBLIC_APP_URL=""
